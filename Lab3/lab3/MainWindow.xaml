<Window x:Class="lab3.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rabin Cryptosystem"
        Height="632" Width="700"
        Background="#282828">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- PARAMETERS -->
        <GroupBox Header="Parameters" Grid.Row="0" FontFamily="Harrington" FontSize="24" Padding="10" Foreground="#FF9DC3F6">
            <Grid Margin="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Labels above -->
                <TextBlock Text="p:" Grid.Row="0" Grid.Column="0" HorizontalAlignment="Center" FontFamily="Harrington" FontSize="20" Foreground="#FF9DC3F6"/>
                <TextBlock Text="q:" Grid.Row="0" Grid.Column="1" HorizontalAlignment="Center" FontFamily="Harrington" FontSize="20" Foreground="#FF9DC3F6"/>
                <TextBlock Text="b:" Grid.Row="0" Grid.Column="2" HorizontalAlignment="Center" FontFamily="Harrington" FontSize="20" Foreground="#FF9DC3F6"/>

                <!-- Input fields -->
                <TextBox Name="pBox" Grid.Row="1" Grid.Column="0" Width="50" HorizontalAlignment="Center" Margin="5" FontFamily="Harrington" FontSize="20" BorderBrush="#FFABADB3" Background="#FFEDB1CC"/>
                <TextBox Name="qBox" Grid.Row="1" Grid.Column="1" Width="50" HorizontalAlignment="Center" Margin="5" FontFamily="Harrington" FontSize="20" BorderBrush="#FFABADB3" Background="#FFEDB1CC"/>
                <TextBox Name="bBox" Grid.Row="1" Grid.Column="2" Width="50" HorizontalAlignment="Center" Margin="5" FontFamily="Harrington" FontSize="20" BorderBrush="#FFABADB3" Background="#FFEDB1CC"/>
            </Grid>
        </GroupBox>

        <!-- FILE SELECTION -->
        <GroupBox Header="Files" Grid.Row="1" FontFamily="Harrington" FontSize="24" Padding="10" Margin="0,10,0,0" Foreground="#FF9DC3F6">
            <Grid Margin="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Cipher label -->
                <TextBlock Text="Cipher:" Grid.Row="0" Grid.Column="0" Margin="5,0,0,0" FontFamily="Harrington" FontSize="18" Foreground="#FF9DC3F6"/>

                <!-- Encrypt file row -->
                <TextBox Name="encryptFileBox" Grid.Row="1" Grid.Column="0" Margin="5" IsReadOnly="True" FontFamily="Harrington" FontSize="18" BorderBrush="#FFABADB3" Background="#FFEDB1CC"/>
                <Button Content="Browse..." Grid.Row="1" Grid.Column="1" Margin="5"
                        Click="SelectEncryptFile_Click" FontSize="18" Background="#FF9DC3F6" Width="100"/>

                <!-- Decipher label -->
                <TextBlock Text="Decipher:" Grid.Row="2" Grid.Column="0" Margin="5,10,0,0" FontFamily="Harrington" FontSize="18" Foreground="#FF9DC3F6"/>

                <!-- Decrypt file row -->
                <TextBox Name="decryptFileBox" Grid.Row="3" Grid.Column="0" Margin="5" IsReadOnly="True" FontFamily="Harrington" FontSize="18" BorderBrush="#FFABADB3" Background="#FFEDB1CC"/>
                <Button Content="Browse..." Grid.Row="3" Grid.Column="1" Margin="5"
                        Click="SelectDecryptFile_Click" FontSize="18" Background="#FF9DC3F6" Width="100"/>
            </Grid>
        </GroupBox>

        <!-- ACTION BUTTONS -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10">
            <Button Content="Encrypt"
                    Width="120" Height="35" Margin="10"
                    FontFamily="Harrington"
                    Click="Encrypt_Click" FontSize="24" Background="#FF9DC3F6"/>

            <Button Content="Decrypt"
                    Width="120" Height="35" Margin="10"
                    FontFamily="Harrington"
                    Click="Decrypt_Click" FontSize="24" Background="#FF9DC3F6"/>
        </StackPanel>

        <!-- OUTPUT LABELS -->
        <Grid Grid.Row="3" Margin="5,0,5,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="Source File:"
                       Grid.Column="0"
                       FontFamily="Harrington"
                       FontSize="24"
                       HorizontalAlignment="Left"
                       Foreground="#FF9DC3F6"/>

            <TextBlock Text="Result:"
                       Grid.Column="1"
                       FontFamily="Harrington"
                       FontSize="24"
                       HorizontalAlignment="Left"
                       Foreground="#FF9DC3F6"/>
        </Grid>

        <!-- OUTPUT BOXES -->
        <Grid Grid.Row="4" Margin="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBox Grid.Column="0"
                     Name="srcOutputBox"
                     FontFamily="Harrington"
                     FontSize="20"
                     AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"
                     TextWrapping="Wrap"
                     IsReadOnly="True"
                     BorderBrush="#FFABADB3"
                     Background="#FFEDB1CC"
                     Margin="0,0,5,0"/>

            <TextBox Grid.Column="2"
                     Name="resultOutputBox"
                     FontFamily="Harrington"
                     FontSize="20"
                     AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"
                     TextWrapping="Wrap"
                     IsReadOnly="True"
                     BorderBrush="#FFABADB3"
                     Background="#FFEDB1CC"
                     Margin="5,0,0,0"/>
        </Grid>
    </Grid>
</Window>